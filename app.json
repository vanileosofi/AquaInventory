{
  "expo": {
    "name": "AquaInventory",
    "slug": "AquaInventory",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon2.png",
    "scheme": "aquainventory",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon2.png",
        "backgroundColor": "#3B44AC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vanileosofi.AquaInventory"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 350,
          "resizeMode": "contain",
          "backgroundColor": "#3B44AC",
          "dark": {
            "backgroundColor": "#3B44AC"
          }
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "AquaInventory necesita acceso a tus fotos para analizar colores.",
          "cameraPermission": "AquaInventory necesita la cámara para fotografiar tus acuarelas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ecebb62b-91a9-4201-a30e-8a27bb732b37"
      }
    }
  }
}